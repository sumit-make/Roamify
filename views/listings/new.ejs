<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust - Create Listing</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <h3>Create a New Listing</h3>
        <form method="POST" action="/listings" novalidate class="row g-3 needs-validation" enctype="multipart/form-data">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input id="title" name="listing[title]" placeholder="Enter title" type="text" class="form-control" required>
                <div class="valid-feedback">It look like good</div>
            </div>

            <div class="mb-3">
                <label for="title" class="form-label">Upload listing image</label>
                <input id="title" name="listing[title]" type="file" class="form-control" required>
                <div class="valid-feedback">It look like good</div>
            </div>
            
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea id="description" name="listing[description]" placeholder="Enter description" class="form-control" required></textarea>
            </div>
            
            <div class="mb-3">
                <label for="image" class="form-label">Image Link</label>
                <input id="image" name="listing[image]" placeholder="Image URL/Link" type="text" class="form-control">
            </div>
            
            <div class="mb-3">
                <label for="price" class="form-label">Price</label>
                <input id="price" name="listing[price]" placeholder="Enter price" type="number" class="form-control" required>
            </div>
            
            <div class="mb-3">
                <label for="country" class="form-label">Country</label>
                <input id="country" name="listing[country]" placeholder="Enter country" type="text" class="form-control" required>
            </div>
            
            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input id="location" name="listing[location]" placeholder="Enter location" type="text" class="form-control">
            </div>
            
            <button type="submit" class="btn btn-dark" style="background-color: red;">Add Listing</button>
        </form>
    </div>
</body>
</html>

